# HighBridge — GHL MCP Server
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────
GHL_API_KEY=your_ghl_private_integration_key_here
GHL_LOCATION_ID=your_sub_account_location_id_here

# ── Optional: Agency-level access (for sub-account management) ────────────
GHL_COMPANY_ID=your_agency_company_id_here

# ── Optional: For future HTTP/SSE transport ───────────────────────────────
PORT=3456
MCP_SECRET=a_random_secret_for_http_mode

# ── Optional: Opt out of anonymous error reporting ────────────────────────
# HighBridge sends anonymous, sanitized error reports (no API keys, no contact
# data) so bugs can be caught and fixed fast. To opt out, uncomment this:
# TELEMETRY_DISABLED=true
